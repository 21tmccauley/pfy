# Copy to .env and fill in. .env is git-ignored.

# Paramify — defaults to STAGE. A stage token against the prod default 401s.
PARAMIFY_API_KEY=
PARAMIFY_URL=https://stage.paramify.com/api/v0
# Optional: default program/project id so you can omit --program-id.
PROGRAM_ID=

# NVD (vuln commands). A key raises the rate limit; optional.
NVD_API_KEY=
